{
  "name": "soundgrid",
  "version": "0.1.0",
  "description": "SoundGrid — an open-source, cross-platform soundboard that plays audio clips into your microphone stream (Windows-first).",
  "author": "SoundGrid Contributors",
  "license": "MIT",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "concurrently -k -n RENDERER,MAIN -c cyan,magenta \"npm:dev:renderer\" \"npm:dev:main\"",
    "dev:renderer": "vite",
    "dev:main": "wait-on tcp:5173 && tsc -p tsconfig.electron.json && cross-env-shell electron .",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.electron.json",
    "build": "npm run build:renderer && npm run build:main",
    "start": "electron .",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder -w",
    "dist:mac": "npm run build && electron-builder -m",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,html,md}\"",
    "check": "tsc -p tsconfig.electron.json --noEmit && tsc -p src/renderer/tsconfig.json --noEmit",
    "lint": "echo \"(lint) add eslint if desired\""
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1"
  }
}
