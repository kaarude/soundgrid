{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "works.earendil.soundgrid",
  "productName": "SoundGrid",
  "directories": {
    "output": "release"
  },
  "files": ["dist/**/*", "assets/logo.svg", "package.json"],
  "asar": true,
  "publish": {
    "provider": "github",
    "owner": "kaarude",
    "repo": "soundgrid"
  },
  "win": {
    "target": [
      { "target": "nsis", "arch": ["x64"] },
      { "target": "portable", "arch": ["x64"] }
    ],
    "artifactName": "SoundGrid-Portable-${version}-${arch}.${ext}",
    "extraResources": [
      {
        "from": "native/audio-engine/target/release/soundgrid-audio.exe",
        "to": "native/soundgrid-audio.exe"
      },
      {
        "from": "vendor/vb-cable/VBCABLE_Driver_Pack45.zip",
        "to": "vendor/VBCABLE_Driver_Pack45.zip"
      }
    ]
  },
  "nsis": {
    "artifactName": "SoundGrid-Setup-${version}-${arch}.${ext}",
    "oneClick": false,
    "perMachine": true,
    "allowToChangeInstallationDirectory": true,
    "include": "build/installer.nsh",
    "license": "build/installer-license.txt",
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "SoundGrid"
  },
  "mac": {
    "target": ["dmg", "zip"],
    "category": "public.app-category.music",
    "icon": "native/audio-engine/target/packaging/icon.png",
    "artifactName": "SoundGrid-${version}-macOS-${arch}.${ext}",
    "hardenedRuntime": true,
    "entitlements": "build/entitlements.mac.plist",
    "entitlementsInherit": "build/entitlements.mac.inherit.plist",
    "notarize": true,
    "extendInfo": {
      "NSMicrophoneUsageDescription": "SoundGrid mixes your microphone with soundboard clips only when passthrough is enabled. Audio stays on this Mac."
    },
    "extraResources": [
      {
        "from": "native/audio-engine/target/universal-apple-darwin/release/soundgrid-audio",
        "to": "native/soundgrid-audio"
      }
    ]
  },
  "dmg": {
    "title": "SoundGrid ${version}",
    "artifactName": "SoundGrid-${version}-macOS-${arch}.${ext}"
  },
  "linux": {
    "target": ["AppImage"],
    "category": "Audio"
  }
}
