{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "works.earendil.soundgrid",
  "productName": "SoundGrid",
  "directories": {
    "output": "release"
  },
  "files": ["dist/**/*", "package.json"],
  "asar": true,
  "win": {
    "target": [
      { "target": "nsis", "arch": ["x64"] },
      { "target": "portable", "arch": ["x64"] }
    ],
    "artifactName": "SoundGrid-Portable-${version}-${arch}.${ext}",
    "extraResources": [
      {
        "from": "native/audio-engine/target/release/soundgrid-audio.exe",
        "to": "native/soundgrid-audio.exe"
      },
      {
        "from": "vendor/vb-cable/VBCABLE_Driver_Pack45.zip",
        "to": "vendor/VBCABLE_Driver_Pack45.zip"
      }
    ]
  },
  "nsis": {
    "artifactName": "SoundGrid-Setup-${version}-${arch}.${ext}",
    "oneClick": false,
    "perMachine": true,
    "allowToChangeInstallationDirectory": true,
    "include": "build/installer.nsh",
    "license": "build/installer-license.txt",
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "SoundGrid"
  },
  "mac": {
    "target": ["dmg"],
    "category": "public.app-category.music",
    "extraResources": [
      {
        "from": "native/audio-engine/target/release/soundgrid-audio",
        "to": "native/soundgrid-audio"
      }
    ]
  },
  "linux": {
    "target": ["AppImage"],
    "category": "Audio"
  }
}
